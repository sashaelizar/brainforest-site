---
// Live commenting, backed by GitHub Discussions via giscus (free, no ads/tracking).
// Inert until Sasha installs the giscus GitHub App and sets these two env vars —
// see GISCUS-SETUP.md for the one-time setup. Sits below the read-only legacy
// Wix comments (CommentsList.astro) so old + new coexist.
const repoId = import.meta.env.PUBLIC_GISCUS_REPO_ID;
const categoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID;
---
{repoId && categoryId && (
  <section class="live-comments">
    <script
      src="https://giscus.app/client.js"
      data-repo="sashaelizar/brainforest-site"
      data-repo-id={repoId}
      data-category="Comments"
      data-category-id={categoryId}
      data-mapping="pathname"
      data-strict="1"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="light"
      data-lang="en"
      crossorigin="anonymous"
      async
    ></script>
  </section>
)}
<style>
  .live-comments { margin-top: 32px; }
</style>
