---
// "Stay in the know" — recreated from the subscribe widget on the original brainforest.org site.
// Submits directly to Sasha's real Kit (ConvertKit) form (id 9693159) rather than Netlify Forms --
// same site-native look, just a Kit-owned backend. Posts through a hidden iframe (not fetch) so it
// works regardless of Kit's CORS policy: a plain form-to-iframe submission is a normal browser
// navigation, not a script-read request, so it's never subject to cross-origin restrictions.
interface Props { variant?: 'band' | 'compact' }
const { variant = 'band' } = Astro.props;
const uid = Math.random().toString(36).slice(2, 9);
---
<section class={`subscribe ${variant}`}>
  <div class={variant === 'band' ? 'wrap narrow' : ''}>
    <div class="subscribe-inner">
      <div class="subscribe-text">
        <h2>Stay in the know</h2>
        <p>Join our mailing list to get exclusive early access to scientific news and health content.</p>
      </div>
      <form
        id={`sub-form-${uid}`}
        class="form"
        method="POST"
        action="https://app.kit.com/forms/9693159/subscriptions"
        target={`sub-frame-${uid}`}
      >
        <input name="fields[first_name]" type="text" placeholder="Your name" required aria-label="Name" />
        <input name="email_address" type="email" placeholder="Enter your email here" required aria-label="Email address" />
        <button type="submit" class="btn">Sign Up</button>
      </form>
      <iframe name={`sub-frame-${uid}`} title="" style="display:none" tabindex="-1" aria-hidden="true"></iframe>
    </div>
    <div id={`sub-thanks-${uid}`} class="thanks" style="display:none">Thanks for submitting! Check your email to confirm.</div>
  </div>
</section>
<script define:vars={{ uid }}>
  const form = document.getElementById(`sub-form-${uid}`);
  form?.addEventListener('submit', () => {
    setTimeout(() => {
      form.style.display = 'none';
      document.getElementById(`sub-thanks-${uid}`).style.display = 'block';
    }, 500);
  });
</script>
<style>
  .subscribe.band { margin-top: 64px; padding: 56px 0; background: var(--cream-2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); text-align: center; }
  .subscribe.band .subscribe-inner { flex-direction: column; align-items: center; max-width: 560px; margin: 0 auto; }
  .subscribe.band h2 { font-size: 28px; margin-bottom: 12px; }
  .subscribe.band p { color: var(--ink-soft); font-size: 16px; max-width: 46ch; margin: 0 auto 26px; }
  .subscribe.band .form { max-width: 520px; margin: 0 auto; width: 100%; }

  .subscribe.compact { margin: 28px 0 40px; padding: 22px 26px; background: var(--cream-2); border: 1px solid var(--line); border-radius: 16px; text-align: left; }
  .subscribe.compact .subscribe-inner { flex-direction: row; align-items: center; justify-content: space-between; flex-wrap: wrap; }
  .subscribe.compact h2 { font-size: 17px; margin-bottom: 4px; }
  .subscribe.compact p { color: var(--ink-soft); font-size: 13.5px; margin: 0; max-width: 40ch; }
  .subscribe.compact .form { flex: 0 0 auto; width: 420px; }
  .subscribe.compact input { padding: 10px 14px; font-size: 14px; }
  .subscribe.compact .btn { padding: 10px 18px; font-size: 13px; }
  .subscribe.compact .thanks { font-size: 14px; }
  @media (max-width: 640px){ .subscribe.compact .subscribe-inner { flex-direction: column; align-items: stretch; text-align: center; } .subscribe.compact .form { width: 100%; } }

  .subscribe-inner { display: flex; gap: 16px; }
  .subscribe .form { display: flex; flex-direction: row; flex-wrap: wrap; gap: 10px; }
  .subscribe .form input { flex: 1 1 140px; }
  .subscribe .form .btn { flex: 0 0 auto; }
  .subscribe input { width: 100%; padding: 13px 16px; border-radius: 10px; border: 1px solid var(--line); font-size: 15px; font-family: var(--sans); background: var(--cream); }
  .subscribe input:focus { outline: 2px solid var(--green-bright); }
  .subscribe .btn { padding: 13px 24px; }
  .subscribe .thanks { font-size: 15px; color: var(--green); font-weight: 600; margin-top: 14px; }
  @media (max-width: 480px){ .subscribe .form { flex-direction: column; } }
</style>
