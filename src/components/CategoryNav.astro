---
import { getCollection } from 'astro:content';
import { catSlug, CATEGORY_ORDER } from '../site';
interface Props { active?: string[]; }
const { active = [] } = Astro.props;

// Category list with counts + a small representative thumbnail (most recent post's hero).
const posts = await getCollection('posts');
const cats = CATEGORY_ORDER
  .map(name => {
    const inCat = posts
      .filter(p => p.data.categories.includes(name))
      .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));
    return { name, slug: catSlug(name), count: inCat.length, hero: inCat[0]?.data.hero };
  })
  .filter(c => c.count > 0);
---
<nav class="catnav" aria-label="Browse by topic">
  <span class="catnav-label">Browse by topic</span>
  <div class="catnav-list">
    <a href="/posts" class="catnav-item all">All Articles <span class="catnav-count">{posts.length}</span></a>
    {cats.map(c => (
      <a href={`/category/${c.slug}`} class={`catnav-item ${active.includes(c.name) ? 'active' : ''}`}>
        {c.hero && <span class="catnav-thumb"><img src={c.hero} alt="" loading="lazy" /></span>}
        <span class="catnav-name">{c.name}</span>
        <span class="catnav-count">{c.count}</span>
      </a>
    ))}
  </div>
</nav>
<style>
  /* Fills the article text column (parent sets the width); a horizontal pill list
     that only wraps to a new row when it overflows the article text width. */
  .catnav { margin: 0 0 22px; padding-bottom: 20px; border-bottom: 1px solid var(--line); }
  .catnav-label { display: block; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); font-weight: 700; margin-bottom: 12px; }
  .catnav-list { display: flex; flex-wrap: wrap; gap: 8px; }
  .catnav-item { display: inline-flex; align-items: center; gap: 7px; padding: 4px 11px 4px 5px; border: 1px solid var(--line); border-radius: 100px; background: var(--cream-2); text-decoration: none; color: var(--ink); font-size: 13px; line-height: 1; transition: border-color .15s ease, transform .12s ease; }
  .catnav-item:hover { border-color: var(--green); transform: translateY(-1px); }
  .catnav-item.active { border-color: var(--green); background: #ecf5f0; }
  .catnav-item.all { padding: 4px 13px; font-weight: 700; background: var(--ink); color: var(--cream); border-color: var(--ink); }
  .catnav-item.all:hover { background: var(--green); border-color: var(--green); }
  .catnav-thumb { width: 20px; height: 20px; border-radius: 50%; overflow: hidden; flex: 0 0 auto; background: var(--line); }
  .catnav-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .catnav-name { font-weight: 600; white-space: nowrap; }
  .catnav-count { font-size: 10.5px; font-weight: 700; color: var(--ink-soft); background: var(--cream); border-radius: 100px; padding: 2px 6px; }
  .catnav-item.all .catnav-count { color: var(--cream); background: rgba(255,255,255,0.18); }
  .catnav-item.active .catnav-count { color: var(--green); }
</style>
