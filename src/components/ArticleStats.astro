---
// Shows view/comment/like stats at the bottom of an article: the historical number from the
// original Wix site (src/data/legacy-stats.json), plus a live count since each counter went live
// on the new site, added together. The live counts only work once the site is deployed to Netlify
// (they call Netlify Functions) — locally, or before that's connected, it just shows the legacy
// number with no error. The like button is a one-time click per browser (remembered via
// localStorage) that fills the heart and bumps the count; no login system, so it's not
// tamper-proof, just a lightweight "someone liked this" signal like Wix's original.
import legacyStats from '../data/legacy-stats.json';

interface Props { slug: string }
const { slug } = Astro.props;
const stats = (legacyStats as Record<string, { views: number; comments: number; likes: number }>)[slug]
  ?? { views: 0, comments: 0, likes: 0 };
---
<div class="article-stats" data-slug={slug} data-legacy-views={stats.views} data-legacy-likes={stats.likes}>
  <span class="stat views">
    <span class="stat-num" data-role="views">{stats.views.toLocaleString()}</span> views
  </span>
  <span class="stat">{stats.comments.toLocaleString()} comment{stats.comments === 1 ? '' : 's'}</span>
  <button type="button" class="stat like-btn" data-role="like-btn" aria-pressed="false" aria-label="Like this article">
    <svg class="heart" viewBox="0 0 24 24" width="17" height="17" aria-hidden="true">
      <path d="M12 20.5s-7.5-4.6-10-9.3C0.3 7.9 2 4.5 5.4 4c2.1-.3 4 .8 6.6 3.4C14.6 4.8 16.5 3.7 18.6 4c3.4.5 5.1 3.9 3.4 7.2-2.5 4.7-10 9.3-10 9.3z"/>
    </svg>
    <span class="stat-num" data-role="likes">{stats.likes.toLocaleString()}</span>
    <span class="like-label">like<span data-role="like-plural">{stats.likes === 1 ? '' : 's'}</span></span>
  </button>
</div>

<script>
  const el = document.querySelector('.article-stats') as HTMLElement | null;
  if (el) {
    const slug = el.dataset.slug ?? '';
    const legacyViews = Number(el.dataset.legacyViews || 0);
    const legacyLikes = Number(el.dataset.legacyLikes || 0);

    fetch(`/api/track-view?slug=${encodeURIComponent(slug)}`)
      .then((r) => (r.ok ? r.json() : null))
      .then((data) => {
        if (data && typeof data.newSiteViews === 'number') {
          const numEl = el.querySelector('[data-role="views"]');
          if (numEl) numEl.textContent = (legacyViews + data.newSiteViews).toLocaleString();
        }
      })
      .catch(() => {});

    const likeBtn = el.querySelector('[data-role="like-btn"]') as HTMLButtonElement | null;
    const likeNumEl = el.querySelector('[data-role="likes"]') as HTMLElement | null;
    const likePluralEl = el.querySelector('[data-role="like-plural"]') as HTMLElement | null;
    const storageKey = `liked-${slug}`;
    let liveLikes = 0; // likes since the counter went live, tracked separately from the legacy count

    const render = () => {
      const total = legacyLikes + liveLikes;
      if (likeNumEl) likeNumEl.textContent = total.toLocaleString();
      if (likePluralEl) likePluralEl.textContent = total === 1 ? '' : 's';
    };

    if (localStorage.getItem(storageKey) === '1') {
      likeBtn?.classList.add('liked');
      likeBtn?.setAttribute('aria-pressed', 'true');
    }

    likeBtn?.addEventListener('click', () => {
      if (localStorage.getItem(storageKey) === '1') return; // already liked from this browser
      localStorage.setItem(storageKey, '1');
      likeBtn.classList.add('liked');
      likeBtn.setAttribute('aria-pressed', 'true');
      liveLikes += 1;
      render();
      fetch(`/api/track-like?slug=${encodeURIComponent(slug)}`, { method: 'POST' }).catch(() => {});
    });
  }
</script>

<style>
  .article-stats { display: flex; gap: 18px; flex-wrap: wrap; align-items: center; margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--line); font-size: 14px; color: var(--ink-soft); }
  .article-stats .stat-num { font-weight: 600; color: var(--ink); }
  .like-btn { display: inline-flex; align-items: center; gap: 6px; background: none; border: none; padding: 0; margin: 0; font: inherit; color: inherit; cursor: pointer; }
  .like-btn .heart { fill: none; stroke: var(--ink-soft); stroke-width: 1.6; transition: fill .15s ease, stroke .15s ease, transform .15s ease; }
  .like-btn:hover .heart { stroke: var(--green); transform: scale(1.08); }
  .like-btn.liked .heart { fill: #e0554f; stroke: #e0554f; }
  .like-btn.liked { cursor: default; }
  .like-btn.liked:hover .heart { transform: none; }
</style>
