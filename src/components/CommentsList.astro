---
// Historical comments carried over from the original Wix site (pulled from Sasha's Wix Comments
// dashboard on 2026-07-10, since the public page's comment widget wasn't rendering the actual
// text for scraping — see src/data/legacy-comments.json). No new commenting system yet; this is
// a read-only display of the old thread.
import { fmtDate } from '../site';
import legacyComments from '../data/legacy-comments.json';

interface Props { slug: string }
const { slug } = Astro.props;
type Comment = { author: string; date: string; text: string; likes: number };
const comments = ((legacyComments as Record<string, Comment[]>)[slug]) ?? [];
---
{comments.length > 0 && (
  <section class="comments">
    <h2>{comments.length} comment{comments.length === 1 ? '' : 's'}</h2>
    <ul class="comment-list">
      {comments.map((c) => (
        <li class="comment">
          <div class="comment-head">
            <span class="comment-author">{c.author}</span>
            <span class="comment-date">{fmtDate(c.date)}</span>
          </div>
          <p class="comment-text">{c.text}</p>
          {c.likes > 0 && (
            <p class="comment-likes">♥ {c.likes} like{c.likes === 1 ? '' : 's'}</p>
          )}
        </li>
      ))}
    </ul>
  </section>
)}
<style>
  .comments { margin-top: 32px; }
  .comments h2 { font-size: 20px; margin-bottom: 18px; }
  .comment-list { list-style: none; display: flex; flex-direction: column; gap: 18px; }
  .comment { background: var(--cream-2); border: 1px solid var(--line); border-radius: 14px; padding: 18px 20px; }
  .comment-head { display: flex; align-items: baseline; gap: 10px; margin-bottom: 8px; flex-wrap: wrap; }
  .comment-author { font-weight: 600; color: var(--ink); font-size: 14.5px; }
  .comment-date { font-size: 12.5px; color: var(--ink-soft); }
  .comment-text { font-size: 15px; line-height: 1.6; color: #2a382f; }
  .comment-likes { font-size: 12.5px; color: var(--green); margin-top: 8px; font-weight: 600; }
</style>
