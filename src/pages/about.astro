---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SOCIAL } from '../site';

// Simple sleek line icons (24x24, stroke-based, outline only -- no fills) representing each area.
const icons = {
  brain: '<path d="M8.5 4C6.6 4 5 5.6 5 7.5c0 .4.1.8.2 1.1C4 9.3 3.2 10.7 3.2 12.3c0 1.6.9 3 2.2 3.7-.1.3-.1.6-.1 1 0 1.9 1.5 3.5 3.4 3.5.3 0 .6 0 .9-.1.6.9 1.6 1.6 2.9 1.6h.1V6.1C12.6 4.9 10.7 4 8.5 4z"/><path d="M15.5 4c1.9 0 3.5 1.6 3.5 3.5 0 .4-.1.8-.2 1.1 1.2.7 2 2.1 2 3.7 0 1.6-.9 3-2.2 3.7.1.3.1.6.1 1 0 1.9-1.5 3.5-3.4 3.5-.3 0-.6 0-.9-.1-.6.9-1.6 1.6-2.9 1.6h-.1V6.1C11.4 4.9 13.3 4 15.5 4z"/>',
  microbe: '<ellipse cx="12" cy="12.5" rx="6" ry="4.6" transform="rotate(-18 12 12.5)"/><path d="M6.2 9.3 4 7.6M17.2 8.4l2.3-1.3M6.8 17l-1.7 2.2M17.6 16.2l1.9 1.7M12.5 6.8 12.2 4"/>',
  immune: '<path d="M12 4.3c-1 0-1.7.8-1.7 1.7 0 .3.1.6.2.8-1.4.3-2.5 1.5-2.5 3 0 .2 0 .4.1.6-1.2.4-2.1 1.5-2.1 2.8 0 1.1.6 2 1.5 2.5-.1.3-.1.5-.1.8 0 1.6 1.3 2.9 2.9 2.9.3 0 .6 0 .8-.1.5.8 1.4 1.4 2.4 1.4 1.6 0 2.9-1.3 2.9-2.9 0-.3 0-.5-.1-.8.9-.5 1.5-1.4 1.5-2.5 0-1.3-.9-2.4-2.1-2.8.1-.2.1-.4.1-.6 0-1.5-1.1-2.7-2.5-3 .1-.2.2-.5.2-.8 0-.9-.8-1.7-1.7-1.7z"/><circle cx="12" cy="13" r="2"/>',
  apple: '<path d="M12 9c-.9-1.2-2.4-1.8-3.8-1.4-2.1.5-3.5 2.6-3.5 5 0 3.9 2.6 8.2 5.4 8.2.8 0 1.4-.3 2.1-.3s1.3.3 2.1.3c2.8 0 5.4-4.3 5.4-8.2 0-2.2-1.2-4.1-3-4.8-1.2-.5-2.5-.2-3.4.6"/><path d="M12 9V5.3"/><path d="M12 5.3c.9-1 2.3-1.3 3.4-.7"/>',
};

const areas = [
  {
    name: 'Neuroscience & Endocrinology',
    href: '/category/neuroscience',
    icon: icons.brain,
    copy: 'Published topics include psychedelic pharmacology, the cell and molecular mechanisms of pineal gland calcification, and hypothalamic-pituitary signaling of estrogen, progesterone, testosterone, and thyroid hormones.',
  },
  {
    name: 'Gut Health & Microbiome',
    href: '/category/gut-microbiome',
    icon: icons.microbe,
    copy: 'A wide range of educational articles using peer-reviewed research — including gastrointestinal layer anatomy and the role of gut microbiota in multiple sclerosis.',
  },
  {
    name: 'Immunity, Aging, and Healthspan',
    href: '/category/aging',
    icon: icons.immune,
    copy: 'A deep dive into the hallmarks of aging, including senescence and mitochondrial dysfunction, and an analysis of natural therapeutic compounds for their ability to slow aging and promote longevity.',
  },
  {
    name: 'Nutrition and Nutraceuticals',
    href: '/category/nutrition',
    icon: icons.apple,
    copy: 'Promote general well-being with precision nutrition, and find information about botanical ingredients and dietary mushroom properties.',
  },
];
---
<BaseLayout title="About" description="About Brainforest Biosciences and Sasha Elizar, M.S.">
  <section class="wrap narrow about">
    <p class="eyebrow">About</p>
    <h1>Brainforest Biosciences</h1>
    <p class="lead">Evidence-based biomedical research meets healthspan extension.</p>

    <p>With deep expertise spanning neuroscience, aging, and gut health, Brainforest Biosciences
      pinpoints root causes and translates them into accessible, actionable steps and real-world
      strategies for functional health.</p>

    <p>With an eye towards lifestyle medicine, outcomes of interest include a regulated nervous
      system, balanced energy and hormones, efficient immunity, better processing, focus, and
      memory, and glowing, radiant skin.</p>

    <p>Explore the full body of work in the <a href="/posts">articles archive</a>, listen to the
      <a href="/podcast">podcast</a>, or check out our <a href="/ebook/leaky-gut-causes">latest ebook on gut health</a>.</p>

    <div class="links">
      {SOCIAL.map(s => <a href={s.href} target="_blank" rel="noopener" class="btn btn-ghost">{s.label}</a>)}
    </div>
  </section>

  <section class="band areas-band">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Therapeutic Areas</p>
        <h2>Where we focus</h2>
        <p>Our goal is to disseminate scientific findings and equip people with the best possible
          information for better health-related decision-making.</p>
      </div>
      <div class="areas-grid">
        {areas.map(a => (
          <a class="area-card" href={a.href}>
            <div class="area-title">
              <svg class="area-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={a.icon} />
              <h3>{a.name}</h3>
            </div>
            <p>{a.copy}</p>
            <span class="area-link">Explore →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    .about { padding: 72px 0 0; max-width: 720px; }
    .about h1 { font-size: clamp(36px, 6vw, 56px); }
    .about .lead { font-size: 20px; color: var(--green); font-weight: 600; margin: 20px 0 24px; }
    .about p { margin-bottom: 1.1em; font-size: 17px; line-height: 1.75; }
    .links { display: flex; gap: 12px; flex-wrap: wrap; margin: 28px 0; }

    .areas-band { padding: 64px 0 80px; }
    .section-head { max-width: 60ch; margin-bottom: 40px; }
    .section-head h2 { font-size: clamp(26px, 3.6vw, 38px); margin-top: 10px; }
    .section-head p { color: var(--ink-soft); margin-top: 14px; font-size: 16px; }
    .areas-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
    @media (max-width: 700px){ .areas-grid { grid-template-columns: 1fr; } }
    .area-card { display: block; background: var(--cream-2); border: 1px solid var(--line); border-radius: 16px; padding: 26px 28px; text-decoration: none; color: inherit; transition: transform .15s ease, box-shadow .15s ease; }
    .area-card:hover { transform: translateY(-2px); box-shadow: 0 16px 34px -20px rgba(20,33,28,0.4); }
    .area-title { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
    .area-icon { flex-shrink: 0; width: 26px; height: 26px; color: var(--green); }
    .area-card h3 { font-size: 23px; line-height: 1.2; color: var(--ink); }
    .area-card p { color: var(--ink-soft); font-size: 14.5px; line-height: 1.6; margin-bottom: 14px; }
    .area-link { font-size: 13px; font-weight: 600; color: var(--green); }
  </style>
</BaseLayout>
