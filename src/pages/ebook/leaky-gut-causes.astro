---
import BaseLayout from '../../layouts/BaseLayout.astro';
// Lead-magnet landing page, recreated from the original brainforest.org/leaky-gut-causes-ebook.
// The opt-in form is a front-end demo — wiring it to an email provider + ebook delivery is in BUILD-NOTES.md.
const coverImg = '/images/leaky-gut-causes/00_cover_25f1b00ace5d.jpg';
const benefits = [
  'A 35-page guide to the barriers standing between you and your detox, energy, and physique goals.',
  'How to spot the food sensitivities behind bloating, cystic acne, joint pain, air hunger, and brain fog.',
  'The hidden chemicals lurking in "health foods" — and how to shop organic without overpaying.',
  'How common medications and antibiotics quietly reshape your gut.',
  'The research on bioplastics, microplastics, and what you are actually ingesting.',
  'Gut microbiota and the foods that help protect against ionizing radiation.',
];
---
<BaseLayout
  title="14 Causes of Leaky Gut — Free Guide"
  description="A free comprehensive guide for self-healers and functional medicine practitioners: the 14 causes of leaky gut and how to avoid them."
  image={coverImg}
>
  <section class="lead">
    <div class="wrap grid">
      <div class="copy">
        <p class="eyebrow">Free download</p>
        <h1>14 Causes of Leaky Gut (And How to Avoid Them)</h1>
        <p class="sub">A free comprehensive guide for self-healers and functional medicine practitioners.</p>

        <ul class="benefits">
          {benefits.map(b => <li>{b}</li>)}
        </ul>

        <p class="symptoms">Inside: the symptoms that signal a compromised gut barrier — pain, headaches,
          digestive issues, food allergies, breakouts, brain fog, fatigue, depression, anxiety,
          shortness of breath, and recurrent infections.</p>
      </div>

      <aside class="optin">
        <div class="cover"><img src={coverImg} alt="14 Causes of Leaky Gut ebook cover" /></div>
        <h2>Yes, I want the free guide</h2>
        <form
          class="form"
          name="leaky-gut-ebook"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          onsubmit="event.preventDefault(); this.style.display='none'; document.getElementById('thanks').style.display='block';"
        >
          <input type="hidden" name="form-name" value="leaky-gut-ebook" />
          <p hidden><label>Skip: <input name="bot-field" /></label></p>
          <div class="row">
            <input name="first_name" type="text" placeholder="First name" required aria-label="First name" />
            <input name="last_name" type="text" placeholder="Last name" required aria-label="Last name" />
          </div>
          <input name="email" type="email" placeholder="you@email.com" required aria-label="Email address" />
          <button type="submit" class="btn">Send Me the Guide</button>
          <p class="fine">No spam. Unsubscribe anytime.</p>
        </form>
        <div id="thanks" class="thanks" style="display:none">
          <h3>Check your inbox 📩</h3>
          <p>Your guide is on its way. (Demo: email delivery wiring is in the build backlog.)</p>
        </div>
      </aside>
    </div>
  </section>

  <style>
    .lead { padding: 64px 0 40px; }
    .grid { display: grid; grid-template-columns: 1.15fr .85fr; gap: 52px; align-items: start; }
    @media (max-width: 820px){ .grid { grid-template-columns: 1fr; gap: 36px; } }
    .copy h1 { font-size: clamp(30px, 4.6vw, 46px); line-height: 1.12; margin-top: 6px; }
    .copy .sub { font-size: 19px; color: var(--ink-soft); margin: 18px 0 26px; }
    .benefits { list-style: none; margin: 0 0 24px; padding: 0; }
    .benefits li { position: relative; padding: 10px 0 10px 30px; border-bottom: 1px solid var(--line); font-size: 16px; color: #2a382f; }
    .benefits li::before { content: "✓"; position: absolute; left: 0; top: 10px; color: var(--green); font-weight: 700; }
    .symptoms { font-size: 15px; color: var(--ink-soft); }

    .optin { background: var(--cream-2); border: 1px solid var(--line); border-radius: 20px; padding: 28px; position: sticky; top: 88px; }
    .cover { border-radius: 12px; overflow: hidden; border: 1px solid var(--line); margin-bottom: 22px; box-shadow: 0 20px 40px -22px rgba(20,33,28,0.5); }
    .cover img { width: 100%; display: block; }
    .optin h2 { font-size: 24px; margin-bottom: 18px; }
    .form { display: flex; flex-direction: column; gap: 12px; }
    .row { display: flex; gap: 12px; }
    .form input { flex: 1; width: 100%; padding: 13px 16px; border-radius: 10px; border: 1px solid var(--line); font-size: 15px; font-family: var(--sans); background: var(--cream); }
    .form input:focus { outline: 2px solid var(--green-bright); }
    .form .btn { margin-top: 4px; text-align: center; padding: 14px; }
    .fine { font-size: 12px; color: var(--ink-soft); text-align: center; margin-top: 2px; }
    .thanks { text-align: center; padding: 24px 0; }
    .thanks h3 { font-size: 22px; margin-bottom: 8px; }
    .thanks p { color: var(--ink-soft); font-size: 14px; }
  </style>
</BaseLayout>
