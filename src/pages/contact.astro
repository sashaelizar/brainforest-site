---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL } from '../site';
---
<BaseLayout title="Contact" description="Get in touch with Brainforest Biosciences.">
  <section class="wrap narrow contact">
    <p class="eyebrow">Contact</p>
    <h1>Get in touch</h1>
    <p class="lead">Questions, collaborations, or just want to say hello? Send a note below,
      or reach out through any of the channels beneath it.</p>

    <form
      id="contact-form"
      class="form"
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
    >
      <input type="hidden" name="form-name" value="contact" />
      <p hidden><label>Skip: <input name="bot-field" /></label></p>
      <div class="row">
        <input name="name" type="text" placeholder="Your name" required aria-label="Name" />
        <input name="email" type="email" placeholder="you@email.com" required aria-label="Email address" />
      </div>
      <textarea name="message" placeholder="What's on your mind?" required aria-label="Message" rows="5"></textarea>
      <button type="submit" class="btn">Send message</button>
    </form>
    <div id="contact-thanks" class="thanks" style="display:none">
      <h3>Thanks for reaching out 🌿</h3>
      <p>Your message is on its way — I'll get back to you soon.</p>
    </div>
    <p id="contact-error" class="error" style="display:none">
      Something went wrong sending that — mind trying again, or emailing directly instead?
    </p>

    <div class="links">
      {SOCIAL.map(s => <a href={s.href} target="_blank" rel="noopener" class="btn btn-ghost">{s.label}</a>)}
    </div>
  </section>
  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const body = new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString();
      fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body,
      })
        .then((res) => {
          if (!res.ok) throw new Error(`${res.status}`);
          form.style.display = 'none';
          document.getElementById('contact-thanks')!.style.display = 'block';
        })
        .catch(() => {
          document.getElementById('contact-error')!.style.display = 'block';
        });
    });
  </script>
  <style>
    .contact { padding: 72px 0; max-width: 720px; }
    .contact h1 { font-size: clamp(34px, 6vw, 52px); }
    .contact .lead { font-size: 19px; color: var(--ink-soft); margin: 20px 0 28px; line-height: 1.7; }
    .form { display: flex; flex-direction: column; gap: 12px; margin-bottom: 36px; }
    .row { display: flex; gap: 12px; }
    .form input, .form textarea { width: 100%; padding: 13px 16px; border-radius: 10px; border: 1px solid var(--line); font-size: 15px; font-family: var(--sans); background: var(--cream); resize: vertical; }
    .form input:focus, .form textarea:focus { outline: 2px solid var(--green-bright); }
    .form .btn { align-self: flex-start; padding: 13px 26px; }
    @media (max-width: 560px){ .row { flex-direction: column; } }
    .thanks { padding: 20px 0 36px; }
    .thanks h3 { font-size: 20px; margin-bottom: 6px; }
    .thanks p { color: var(--ink-soft); font-size: 14px; }
    .error { color: #b3453a; font-size: 14px; margin: -12px 0 24px; }
    .links { display: flex; gap: 12px; flex-wrap: wrap; }
  </style>
</BaseLayout>
