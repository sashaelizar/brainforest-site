---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL } from '../site';
---
<BaseLayout title="Contact" description="Get in touch with Infinite Emergence.">
  <section class="wrap narrow contact">
    <p class="eyebrow">Contact</p>
    <h1>Get in touch</h1>
    <p class="lead">Questions, collaborations, or just want to say hello? Reach out through
      any of the channels below.</p>
    <div class="links">
      {SOCIAL.map(s => <a href={s.href} target="_blank" rel="noopener" class="btn btn-ghost">{s.label}</a>)}
    </div>
    <p class="note">Contact form to be wired up in the final build (Netlify Forms works free).</p>
  </section>
  <style>
    .contact { padding: 72px 0; max-width: 720px; }
    .contact h1 { font-size: clamp(34px, 6vw, 52px); }
    .contact .lead { font-size: 19px; color: var(--ink-soft); margin: 20px 0 28px; line-height: 1.7; }
    .links { display: flex; gap: 12px; flex-wrap: wrap; }
    .note { font-size: 13px; color: var(--ink-soft); opacity: .8; margin-top: 26px; }
  </style>
</BaseLayout>
